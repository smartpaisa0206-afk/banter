# ---- Database ----
DB_DRIVER=libsql
# Local dev (file-based). For prod use a Turso URL: libsql://xxxx.turso.io
DATABASE_URL="file:./banter.db"

# ---- Auth / Security ----
SESSION_SECRET="change-me-to-a-long-random-string-please-32plus-chars"
# 32+ char key used to encrypt stored messages at rest (AES-256-GCM)
APP_ENCRYPTION_KEY="change-me-also-to-a-long-random-string-32plus"

# ---- Branding ----
NEXT_PUBLIC_BRAND_NAME="Banter"
NEXT_PUBLIC_BRAND_TAGLINE="Say the right thing to the right person."

# ---- LLM (optional; app falls back to templates without it) ----
# Free options: "ollama" (local, no key) or "groq" (free key from groq.com)
LLM_PROVIDER=""
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."
# OLLAMA_HOST="http://localhost:11434"
# OLLAMA_MODEL="llama3"
# GROQ_API_KEY="gsk_..."
# GROQ_MODEL="llama-3.1-8b-instant"

# ---- Email (OTP / magic-code login) ----
# In dev (no key) the 6-digit code is logged to the server console AND
# returned to the client so you can test without a real email provider.
# In production set a Resend key so codes are actually emailed.
# RESEND_API_KEY="re_..."
# EMAIL_FROM="Banter <onboarding@resend.dev>"

# ---- Google sign-in (OAuth2) ----
# Create credentials at https://console.cloud.google.com (authorized redirect
# URI: <APP_BASE_URL>/api/auth/google/callback). Leave blank to disable.
# GOOGLE_CLIENT_ID="....apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="GOCSPX-..."
# APP_BASE_URL="https://your-domain.com"

# ---- Payments (Stripe, optional) ----
# Prices localize by visitor country + device automatically (see src/lib/pricing.ts).
# Wire Stripe here for real checkout:
# STRIPE_SECRET_KEY="sk_..."
# STRIPE_BASIC_PRICE="price_..."
# STRIPE_PREMIUM_PRICE="price_..."

# ---- Mobile / native keyboard (Phase 2) ----
# The Android keyboard (android/) calls these endpoints with a device token:
#   POST /api/mobile/login        -> { token }
#   POST /api/mobile/generate     -> { variants, tip, coachNote, ... }
# No extra env needed — the keyboard just needs a reachable Banter server
# (HTTPS) and the user's normal Banter login.

# ---- Admin bootstrap (only used by `npm run setup`) ----
ADMIN_EMAIL="admin@banter.app"
ADMIN_PASSWORD="admin1234"
